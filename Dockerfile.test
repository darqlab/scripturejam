# Test/dev image — runs server via tsx (no TS compilation, no SvelteKit build).
# Used only for the /opt/yard/scripturejam test deployment.
# NOT for production (use app/server/Dockerfile for that).
#
# Flat layout — no pnpm workspaces to avoid build-script approval prompts in
# pnpm v10; @scripturejam/types source is copied alongside the server source
# and resolved via a local path in node_modules.

FROM node:22-alpine

WORKDIR /app

# Self-contained package.json — all runtime + tsx deps, no workspace references
COPY docker/test-package.json ./package.json

RUN npm install --legacy-peer-deps

# Copy server source
COPY app/server/src ./src

# Copy types source into node_modules so bare imports resolve
COPY app/packages/types/src ./node_modules/@scripturejam/types/src
COPY docker/types-package.json ./node_modules/@scripturejam/types/package.json

# Copy content directory (schema files only at this stage; actual YAML added by pipeline)
COPY content ./content

EXPOSE 3000

CMD ["node_modules/.bin/tsx", "src/index.ts"]
