# ── Required ──────────────────────────────────────────────────────────────────
# HMAC secret used to hash IPs for the audit log. Generate with:
#   openssl rand -hex 32
IP_HASH_SECRET=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://scripturejam:changeme@postgres:5432/scripturejam

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Session / game knobs ──────────────────────────────────────────────────────
MIN_QUESTIONS_TO_START=5
MAX_QUESTIONS_PER_SESSION=20
QUESTION_DURATION_MS=20000
MAX_QUESTIONS_PER_CUSTOM_PACK=50
MAX_CUSTOM_PACK_UPLOAD_BYTES=262144

# ── Session TTLs (seconds) ────────────────────────────────────────────────────
SESSION_TTL_EMPTY_SECONDS=900
SESSION_TTL_ACTIVE_SECONDS=14400

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_IP_PER_HOUR=5
RATE_LIMIT_GLOBAL_PER_HOUR=100

# ── Results retention ─────────────────────────────────────────────────────────
# Days to keep session results in Postgres. Set to 0 to keep forever.
RESULTS_RETENTION_DAYS=90

# ── Public URL ────────────────────────────────────────────────────────────────
# Used to construct join URLs and QR codes. Set to your public domain.
PUBLIC_URL=https://quiz.example.com

# ── Observability (optional) ──────────────────────────────────────────────────
# Set to "true" to expose /metrics (Prometheus). Off by default.
ENABLE_METRICS=false

# ── Cloudflare Tunnel (compose.cloudflare.yml only) ──────────────────────────
TUNNEL_TOKEN=

# ── Caddy (compose.caddy.yml only) ────────────────────────────────────────────
PUBLIC_HOSTNAME=quiz.example.com

# ── Postgres credentials (used by docker compose) ────────────────────────────
POSTGRES_USER=scripturejam
POSTGRES_PASSWORD=changeme
POSTGRES_DB=scripturejam
